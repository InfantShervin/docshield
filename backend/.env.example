# DocShield Backend Configuration Template
# Copy this file to .env and fill in the actual values.

# Database connection URL (Supabase/PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# Security settings
# Generate a random secret key for session management
SECRET_KEY=generate-a-safe-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# (Optional) OpenAI API Key for AI Chat functionality
OPENAI_API_KEY=

# Application settings
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
MODEL_PATH=./sgat_layoutlm_model.pth
